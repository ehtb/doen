# Doen — production environment configuration
# Copy to .env and fill in all values before running docker-compose.prod.yml.
#
#   cp .env.example .env   # then edit with your credentials
#
# This file is for production use (docker-compose.prod.yml).
# For local development, use backend/.env with docker-compose.yml instead.

# ── Database ──────────────────────────────────────────────────────────────────
# Managed Postgres with pgvector extension required.
# Append ?sslmode=require for TLS (mandatory on most managed providers).
# Providers with pgvector support: Supabase, Neon, Render, DigitalOcean Managed
# Postgres (pgvector available on all plans), Railway, AWS RDS with pg_vector.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
# External Redis 6.0+ required (pub/sub and keyspace notifications used).
# Use rediss:// (double-s) for TLS-encrypted connections.
REDIS_URL=redis://user:password@host:6379/0

# ── MCP transport ─────────────────────────────────────────────────────────────
# "stdio"  — default; the MCP server runs as a subprocess on the same machine.
# "http"   — mounts the MCP server at /mcp on the backend (port 8000).
#            Required for the collaborative model: PM on web, engineer's Claude
#            Code connecting remotely from the same VPC.
#
# WARNING: HTTP MCP is intended for VPC/private network deployment only.
# Do not expose port 8000 to the public internet without authentication (spec 0007).
MCP_TRANSPORT=stdio

# ── LLM provider ─────────────────────────────────────────────────────────────
# OpenRouter routes requests to Claude (spec shaping) and the embedding model.
# One key powers both features. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Model configuration ───────────────────────────────────────────────────────
# Provider base URL — any OpenAI-compatible endpoint works here.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model used for AI-assisted spec shaping.
SHAPING_MODEL=anthropic/claude-sonnet-4.6
# Embedding model and its vector dimension (must match the migration's vector(N) column).
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# ── Application ───────────────────────────────────────────────────────────────
# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info
