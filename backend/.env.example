# Doen — environment configuration
# Copy to .env and set LLM_API_KEY. Everything else has sensible defaults for
# local development; override only what you need to change.
#
#   cp .env.example .env   # then edit LLM_API_KEY
#
# Production: swap DATABASE_URL and REDIS_URL for your managed service URLs.

# ── Required ──────────────────────────────────────────────────────────────────
# API key for the LLM provider. The default provider is OpenRouter (openrouter.ai/keys),
# which routes both spec shaping and embeddings through a single key. Any OpenAI-compatible
# provider works — set LLM_BASE_URL to point at it.
LLM_API_KEY=

# ── Datastores ────────────────────────────────────────────────────────────────
# These localhost defaults work for `make dev` and `docker compose up`.
# For production, replace with your managed service URLs:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
#   REDIS_URL=rediss://user:password@host:6379/0
# Providers with pgvector support: Supabase, Neon, Render, DigitalOcean, Railway, AWS RDS.
DATABASE_URL=postgresql://doen:doen@localhost:5432/doen
REDIS_URL=redis://localhost:6379/0

# ── MCP transport ─────────────────────────────────────────────────────────────
# "stdio"  — MCP server runs as a subprocess (default; works with docker compose exec or local venv).
# "http"   — mounts the MCP server at /mcp on the backend.
#            Use when Claude Code runs on a different machine. VPC/private network only.
MCP_TRANSPORT=stdio

# ── LLM provider ─────────────────────────────────────────────────────────────
# Base URL for an OpenAI-compatible API. Default is OpenRouter; swap to use any other provider.
LLM_BASE_URL=https://openrouter.ai/api/v1
# Model used for AI-assisted spec shaping.
SHAPING_MODEL=anthropic/claude-sonnet-4.6
# Embedding model and its vector dimension (must match the migration's vector(N) column).
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# ── Application ───────────────────────────────────────────────────────────────
# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info
