# Copy this to backend/.env, then add your OpenRouter API key.
#
#     cp backend/.env.example backend/.env   # then edit OPENROUTER_API_KEY
#
# With `docker-compose up`, the database/redis URLs are set automatically to the
# in-network service names, so for the Docker path the only value you must fill in is
# OPENROUTER_API_KEY.

# --- required for the AI features (spec shaping + memory embeddings) ---
# One OpenRouter key powers both: Claude drafts specs, and the embedding model is routed
# through the same provider. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- datastores ---
# These localhost defaults are for running the backend on your host (`make dev`).
# docker-compose overrides them with the postgres/redis service-name URLs.
DATABASE_URL=postgresql://doen:doen@localhost:5432/doen
REDIS_URL=redis://localhost:6379/0

# --- model + provider config (optional — sensible defaults shown) ---
# Provider base URL (any OpenAI-compatible endpoint works).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# The model that drafts specs (AI-assisted shaping).
SHAPING_MODEL=anthropic/claude-sonnet-4.6
# The embedding model + its vector dimension (must match the migration's vector(N)).
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
