# Defaults match docker-compose.yml; copy to .env only to override.
DATABASE_URL=postgresql://doen:doen@localhost:5432/doen
REDIS_URL=redis://localhost:6379/0

# Embeddings (spec 0005). The default provider routes through OpenRouter.
# A key is required to generate embeddings (resolve-time embed, backfill, get_context);
# the app still runs without one — embeddings just stay null until a key is set.
OPENROUTER_API_KEY=
# Optional overrides (defaults shown). EMBEDDING_DIM must match the migration's vector(N).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
